# Copy this file to .env and fill in your real API keys
# cp .env.example .env

# PRIMARY LLM — Groq (recommended — free, 14,400 req/day)
# Get your free key at: https://console.groq.com → API Keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# FALLBACK LLM — Google Gemini
# Get your key at: https://aistudio.google.com → Get API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Parcle Memory API
PARCLE_API_KEY=your_parcle_api_key_here

# Google Cloud Project (optional)
ENTER_PROJECT_ID=eternal-architect

# MongoDB connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=Cluster0
